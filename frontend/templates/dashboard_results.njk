{% extends "layout.njk" %}

{% block content %}
<h1>Search Results</h1>

{% if inmates|length == 0 %}
    <p>No inmates found.</p>
{% else %}
<table>
    <thead>
        <tr>
            <th>Name</th>
            <th>Prison</th>
            <th>View</th>
        </tr>
    </thead>
    <tbody>
    {% for inmate in inmates %}
        <tr>
            <td>{{ inmate.first_name }} {{ inmate.last_name }}</td>
            <td>{{ inmate.prison_name }}</td>
            <td>
                <a href="/dashboard/inmates/{{ inmate.id }}">View Details</a>
            </td>
        </tr>
    {% endfor %}
    </tbody>
</table>
{% endif %}

<a href="/dashboard">← Back to Dashboard</a>
{% endblock %}

