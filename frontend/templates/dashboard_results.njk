{% extends "layout.njk" %}

{% block content %}

<h1 class="govuk-heading-l">Search Results</h1>

{% if inmates|length == 0 %}
    <p class="govuk-body">No inmates found.</p>
{% else %}
    <ul class="govuk-list govuk-list--bullet">
        {% for inmate in inmates %}
            <li>
                <a class="govuk-link" href="/dashboard/inmates/{{ inmate.id }}">
                    {{ inmate.first_name }} {{ inmate.last_name }} — {{ inmate.prison_name }}
                </a>
            </li>
        {% endfor %}
    </ul>
{% endif %}

<a href="/dashboard" class="govuk-link">← Back to search</a>

{% endblock %}


